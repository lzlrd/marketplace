# Offshore config: mirrors the OpenAI Codex CLI's model-provider layout.
# Copy to ~/.offshore/config.toml (or point OFFSHORE_CONFIG at it).

# Active model + provider (provider id refers to a [model_providers.<id>] block,
# or one of the built-ins: ollama, lmstudio, vllm).
model = "dolphin3"
model_provider = "ollama"

# Optional Generation Settings
temperature = 0.3   # set OFFSHORE_TEMPERATURE="" to omit temperature entirely
# max_tokens = 2048
# timeout_ms = 120000        # idle timeout between streamed chunks, not total time
# system_prompt = "..."   # override the built-in unrestricted framing

# --- Providers -------------------------------------------------------------
# The built-in providers (ollama, lmstudio, vllm) already exist with sensible
# defaults, so you don't need to declare them here. Add a [model_providers.<id>]
# block only to define a NEW provider, or to OVERRIDE a built-in's fields — for
# example, to point ollama at a non-default host:
#
#   [model_providers.ollama]
#   base_url = "http://gpu-box.local:11434/v1"
#   wire_api = "chat"          # "chat" (Chat Completions) or "responses" (Responses API)

# Example: a remote OpenAI-compatible gateway with auth + custom headers.
[model_providers.gateway]
name = "Internal Gateway"
base_url = "https://llm.internal.example.com/v1"
env_key = "GATEWAY_API_KEY"                       # API key read from this env var
wire_api = "chat"
request_max_retries = 3
http_headers = { "X-Team" = "platform" }          # static headers
env_http_headers = { "X-Trace-Id" = "TRACE_ID" }  # header value read from env var
query_params = { "api-version" = "2026-01-01" }
